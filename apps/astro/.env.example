# Copy to .env or .env.local. Used by astro.config (site) for canonical URLs, sitemap, etc.
# Public URL of the main Next app (same host users see in the browser when using unified domain).

WEB_MICROFRONTEND_URL=http://127.0.0.1:3000

# Production (Vercel — set on the Astro project):
# WEB_MICROFRONTEND_URL=https://your-web.vercel.app
